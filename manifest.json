{
  "manifest_version": 3,
  "name": "Pudding",
  "version": "1.0",
  "description": "Smooth, delightful web accessibility - making content easier to digest for everyone",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": [
      "config.js", 
      "marked.js", 
      "logger.js",
      "i18n-helper.js",
      "content-translator.js",
      "cognitive-tracker.js",
      "focus-mode.js",
      "complexity-analyzer.js",
      "content-restructurer.js",
      "smart-auto-mode.js",
      "fatigue-detector.js",
      "vocabulary-adapter.js",
      "reading-beam.js",
      "content.js"
    ],
    "css": ["content.css"],
    "run_at": "document_start"
  }],
  "web_accessible_resources": [{
    "resources": ["fonts/*", "config.js"],
    "matches": ["<all_urls>"]
  }],
  "options_page": "options.html"
}
